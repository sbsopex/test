function sparks(x,z,col,n){
  for(let i=0;i<n;i++){ const a=rng()*Math.PI*2, sp=1.2+rng()*3;
    const m=new THREE.Mesh(SHARED.geo.spark, new THREE.MeshBasicMaterial({color:col}));
    m.position.set(x,0.4,z); scene.add(m);
    fxs.push({mesh:m, kind:"spark", life:0.4+rng()*0.3, max:0.7,
      vx:Math.cos(a)*sp, vz:Math.sin(a)*sp, vy:2+rng()*2}); }
}

// projected DOM floating text
const boardWrap = document.querySelector(".board-wrap");
let floatCount=0;
function floatText(x,z,y,text,col,crit){
  if (floatCount>40) return;
  const p=new THREE.Vector3(x,y,z).project(camera);
  if (p.z>1) return;
  const rect=renderer.domElement.getBoundingClientRect(), host=boardWrap.getBoundingClientRect();
  const sx=(p.x*0.5+0.5)*rect.width + (rect.left-host.left);
  const sy=(-p.y*0.5+0.5)*rect.height + (rect.top-host.top);
  const div=document.createElement("div"); div.className="fx-float"+(crit?" crit":"");
  div.textContent=text; div.style.color=col; div.style.left=sx+"px"; div.style.top=sy+"px";
  boardWrap.appendChild(div); floatCount++;
  const start=performance.now(), dur=crit?900:750, rise=crit?54:40;
  (function anim(){ const e=(performance.now()-start)/dur;
    if(e>=1){ div.remove(); floatCount--; return; }
    div.style.transform="translate(-50%,"+(-rise*e)+"px)"; div.style.opacity=String(1-e*e);
    requestAnimationFrame(anim); })();
}

// ---------- damage / combo ----------
function addCombo(){ state.combo++; state.comboTimer=COMBO_WINDOW;
  state.ion.cd=Math.max(0, state.ion.cd-0.3*comboMult());
  el.comboN.textContent=state.combo; el.comboMult.textContent="×"+comboMult().toFixed(1);
  el.combo.classList.add("show"); el.combo.classList.toggle("big",false); void el.combo.offsetWidth; el.combo.classList.add("big"); }
function killEnemy(e){
  const gold=Math.round(e.reward*goldMul());
  state.gold+=gold; state.score+=gold; addCombo();
  floatText(e.x, e.z, e.size+0.3, "+"+gold, "#fcd34d", false);
  sparks(e.x, e.z, ENEMIES[e.type].color, e.boss?16:6);
  scene.remove(e.mesh.group); const i=enemies.indexOf(e); if(i>=0) enemies.splice(i,1);
  if (e.boss){ kick(8); sBoom(); rollDrop(state.currentWave, true); }
  syncHUD();
}
function hurtEnemy(e, dmg, isCrit){
  e.hp-=dmg; e.hit=0.12;
  floatText(e.x, e.z, e.size+0.5, (isCrit?"✦":"")+Math.round(dmg), isCrit?"#ffd84a":"#e8eefb", isCrit);
  if (e.hp<=0) killEnemy(e);
}
function applySlow(e,factor,dur,t){ e.slow=Math.min(e.slow,factor); e.slowUntil=Math.max(e.slowUntil,t+dur); }

function acquire(t,range){ let best=null,bd=-1; for(const e of enemies){ const d=Math.hypot(e.x-t.x,e.z-t.z);
  if(d<=range && e.dist>bd){ best=e; bd=e.dist; } } return best; }

// ---------- Ion Strike ----------
function ionReady(){ return state.ion.cd<=0; }
function fireIon(x,z){
  state.ion.cd=state.ion.cdMax; state.ion.armed=false; sIon(); kick(9);
  const radius=2.3, dmg=60+12*state.currentWave;
  // sky beam
  const beam=new THREE.Mesh(new THREE.CylinderGeometry(0.5,0.2,14,16),
    new THREE.MeshBasicMaterial({color:0xb483ff,transparent:true,opacity:0.85}));
  beam.position.set(x,7,z); scene.add(beam);
  fxs.push({mesh:beam, kind:"ionbeam", life:0.35, max:0.35});
  explosion(x,z,radius,0xb483ff); explosion(x,z,radius*0.6,0xffffff);
  for(let i=enemies.length-1;i>=0;i--){ const e=enemies[i];
    if(Math.hypot(e.x-x,e.z-z)<=radius){ applySlow(e,0.25,1.6,clock); hurtEnemy(e,dmg,true); } }
  syncAbility();
}

// ---------- equipment / loot ----------
function uid(){ return (save.nextId=(save.nextId||1)+1).toString(36)+Math.floor(Math.random()*1e4).toString(36); }
function invById(id){ return save.inventory.find(i=>i.id===id) || null; }
function rarityRoll(wave){
  let w=[60,28,10,2];
  w[1]+=wave*0.5; w[2]+=wave*0.7; w[3]+=wave*0.35; w[0]=Math.max(8,w[0]-wave*0.6);
  const sum=w[0]+w[1]+w[2]+w[3]; let x=Math.random()*sum;
  for(let i=0;i<4;i++){ if(x<w[i]) return i; x-=w[i]; } return 0;
}
function generateItem(rar){
  const R=RARITY[rar], keys=shuffle(STAT_KEYS.slice()).slice(0,R.stats), stats={};
  for(const k of keys){ const [lo,hi]=STAT_DEFS[k].base; stats[k]=Math.round((lo+Math.random()*(hi-lo))*R.mul); }
  const name=ITEM_ADJ[Math.floor(Math.random()*ITEM_ADJ.length)]+" "+ITEM_NOUNS[Math.floor(Math.random()*ITEM_NOUNS.length)];
  return { id:uid(), name, rar, stats };
}
function rollDrop(wave, guaranteed){
  if (!guaranteed && Math.random()>0.15) return;
  const it=generateItem(rarityRoll(wave)); save.inventory.push(it); persist(); sLoot();
  showLoot(it); syncHUD();
}
function showLoot(it){
  const R=RARITY[it.rar];
  el.lootCard.style.setProperty("--rc",R.css);
  el.lootCard.innerHTML='<div class="loot-k">'+R.name+' drop</div><div class="loot-n">'+it.name+'</div>'+
    '<div class="loot-s">'+statLine(it)+'</div><div class="loot-tap">tap to open loadout</div>';
  el.loot.classList.add("show"); clearTimeout(showLoot._t);
  showLoot._t=setTimeout(()=>el.loot.classList.remove("show"),4200);
}
el.lootCard.addEventListener("click", ()=>{ el.loot.classList.remove("show"); openEq(); });
function statLine(it){ return Object.entries(it.stats).map(([k,v])=>STAT_DEFS[k].label+" <b>+"+v+STAT_DEFS[k].suf+"</b>").join(" · "); }

function computeEquip(){
  const e={ atkMul:1, rateMul:1, rangeMul:1, critChance:0, critDmg:0, goldMul:1 };
  for(const id of save.loadout){ const it=invById(id); if(!it) continue;
    for(const [k,v] of Object.entries(it.stats)){
      if(k==="attack") e.atkMul+=v/100; else if(k==="attackSpeed") e.rateMul+=v/100;
      else if(k==="range") e.rangeMul+=v/100; else if(k==="critChance") e.critChance+=v;
      else if(k==="critDamage") e.critDmg+=v; else if(k==="goldFind") e.goldMul+=v/100;
    } }
  state.equip=e;
}
function equipItem(id){
  let slot=save.loadout.indexOf(null);
  if (slot<0) slot=0; // replace first
  // if already equipped elsewhere, remove there
  const ex=save.loadout.indexOf(id); if(ex>=0) save.loadout[ex]=null;
  save.loadout[slot]=id; computeEquip(); persist(); renderEq(); syncHUD();
}
function unequip(slot){ save.loadout[slot]=null; computeEquip(); persist(); renderEq(); syncHUD(); }
function salvage(id){ const it=invById(id); if(!it) return;
  const sl=save.loadout.indexOf(id); if(sl>=0) save.loadout[sl]=null;
  save.inventory=save.inventory.filter(i=>i.id!==id);
  save.cores+=RARITY[it.rar].salvage; computeEquip(); persist(); renderEq(); syncHUD(); sZap(); }
function forge(){ const cost=80; if(save.cores<cost){ toast("Need "+cost+" cores"); return; }
  save.cores-=cost; const it=generateItem(rarityRoll(Math.max(5,state.wave))); save.inventory.push(it);
  persist(); renderEq(); syncHUD(); sLoot(); }


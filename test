function blip(freq,dur,type,vol){ if(state.muted) return; const ac=audio(); if(!ac) return;
  try{ const o=ac.createOscillator(),g=ac.createGain(); o.type=type||"square"; o.frequency.value=freq;
    g.gain.setValueAtTime(vol||0.05, ac.currentTime); g.gain.exponentialRampToValueAtTime(0.0001, ac.currentTime+(dur||0.08));
    o.connect(g).connect(ac.destination); o.start(); o.stop(ac.currentTime+(dur||0.08)); }catch(e){} }
const sShoot=()=>blip(560,0.04,"square",0.022), sZap=()=>blip(900,0.05,"sawtooth",0.02), sBoom=()=>blip(150,0.18,"triangle",0.05),
  sRail=()=>blip(1300,0.08,"sawtooth",0.04), sPlace=()=>blip(740,0.07,"sine",0.05),
  sUp=()=>{ blip(620,0.06,"square",0.04); setTimeout(()=>blip(880,0.07,"square",0.04),60); },
  sHurt=()=>blip(110,0.2,"sawtooth",0.06), sBoss=()=>{ blip(90,0.4,"sawtooth",0.06); blip(180,0.4,"triangle",0.04); },
  sIon=()=>{ blip(1500,0.05,"sawtooth",0.05); setTimeout(()=>blip(120,0.4,"sawtooth",0.07),40); },
  sLoot=()=>{ blip(700,0.07,"sine",0.05); setTimeout(()=>blip(1050,0.09,"sine",0.05),70); setTimeout(()=>blip(1400,0.1,"sine",0.05),150); };

// ---------- helpers ----------
const clamp=(v,a,b)=>v<a?a:v>b?b:v;
function toast(msg){ el.toast.textContent=msg; el.toast.classList.add("show"); clearTimeout(toast._t); toast._t=setTimeout(()=>el.toast.classList.remove("show"),1500); }
const v3 = (x,z,y=0.3)=>new THREE.Vector3(x,y,z);

// ---------- stats with equipment + perks ----------
function statsOf(t){
  const d=TOWERS[t.type], n=t.level-1, u=d.up;
  let dmg=d.dmg*Math.pow(u.dmg,n);
  let rate=d.rate*Math.pow(u.rate||1,n);
  let range=d.range*Math.pow(u.range||1,n);
  dmg *= state.equip.atkMul * state.perk.atkMul * (1 + state.perk.perTowerDmg*towers.length);
  if (state.perk.surge && state.combo>=10) dmg *= 1.3;
  rate *= state.equip.rateMul * state.perk.rateMul;
  range = (range + state.perk.rangeFlat) * state.equip.rangeMul;
  const s={ dmg, rate, range };
  if (d.kind==="frost"){ s.slow=clamp(d.slow*Math.pow(u.slowMul||1,n)*state.perk.slowMul,0.2,1); s.slowDur=d.slowDur+0.2*n; }
  if (d.kind==="shell") s.splash=d.splash*Math.pow(u.splash||1,n)*(1+ (state.perk.splashMul-1));
  return s;
}
function critRoll(){ return Math.random()*100 < (BASE_CRIT + state.equip.critChance + state.perk.critChance); }
function critMult(){ return BASE_CRIT_MULT + (state.equip.critDmg + state.perk.critDmg)/100; }
function goldMul(){ return state.equip.goldMul * state.perk.goldMul * comboMult(); }
function comboMult(){ return 1 + Math.min(state.combo,40)*0.025; }

// ---------- build / economy ----------
function tileFree(c,r){ if(c<0||r<0||c>=COLS||r>=ROWS) return false; if(pathSet.has(c+","+r)) return false; return !towers.some(t=>t.c===c&&t.r===r); }
function place(c,r){
  const key=state.placing; if(!key) return;
  const cost=TOWERS[key].cost;
  if (state.gold<cost){ toast("Not enough credits"); return; }
  if (!tileFree(c,r)){ toast("Can't build there"); return; }
  const mesh=makeTowerMesh(key); mesh.group.position.set(wx(c),0,wz(r)); scene.add(mesh.group);
  const t={ type:key, c, r, x:wx(c), z:wz(r), level:1, invested:cost, upCost:TOWERS[key].up.base, cd:0, yaw:0, mesh, turret:mesh.turret, tip:mesh.tip };
  setPips(t); towers.push(t);
  state.gold-=cost; sPlace(); ringPulse(wx(c),wz(r),TOWERS[key].color);
  if (state.gold<cost) state.placing=null;
  syncShop(); syncHUD();
}
function upgrade(t){ if(t.level>=3) return; if(state.gold<t.upCost){ toast("Not enough credits"); return; }
  state.gold-=t.upCost; t.invested+=t.upCost; t.level++; t.upCost=Math.round(t.upCost*1.7);
  setPips(t); sUp(); ringPulse(t.x,t.z,TOWERS[t.type].color); syncPanel(); syncHUD(); }
function sell(t){ const refund=Math.round(t.invested*0.6); state.gold+=refund; toast("+"+refund+" credits");
  scene.remove(t.mesh.group); const i=towers.indexOf(t); if(i>=0) towers.splice(i,1);
  state.selected=null; SHARED.ring.visible=false; SHARED.rfill.visible=false; syncPanel(); syncHUD(); sZap(); }

// ---------- spawning ----------
const hpScale=w=>Math.pow(1.12,w-1), rewardScale=w=>1+0.04*(w-1), waveBonus=w=>18+w*4;
function spawnEnemy(type){
  const d=ENEMIES[type], hp=Math.round(d.hp*hpScale(state.currentWave));
  const mesh=makeEnemyMesh(type); mesh.group.position.set(waypoints[0].x,0,waypoints[0].z); scene.add(mesh.group);
  enemies.push({ type, x:waypoints[0].x, z:waypoints[0].z, wp:1, dist:0, hp, maxHp:hp,
    speed:d.speed, slow:1, slowUntil:0, reward:Math.round(d.reward*rewardScale(state.currentWave)),
    leak:d.leak, size:d.size, boss:!!d.boss, mesh, hit:0 });
  if (d.boss){ sBoss(); kick(7); }
}
let seed=1337; function rng(){ seed=(seed*1664525+1013904223)>>>0; return seed/4294967296; }
function shuffle(a){ for(let i=a.length-1;i>0;i--){ const j=Math.floor(rng()*(i+1)); [a[i],a[j]]=[a[j],a[i]]; } return a; }
const gapFor=t=>t==="swarm"?0.20:t==="runner"?0.45:t==="brute"?0.95:0.62;
function generateWave(w){
  const list=[];
  if (w%5===0){
    const esc=3+Math.floor(w/2);
    for(let i=0;i<esc;i++) list.push({type:i%2?"brute":"drone",gap:0.55});
    const bosses=1+Math.floor(Math.max(0,w-5)/10);
    for(let b=0;b<bosses;b++){ list.push({type:"boss",gap:1.3}); for(let k=0;k<3;k++) list.push({type:"swarm",gap:0.22}); }
  } else {
    const u=[]; const dr=4+w, ru=Math.floor(w/2), br=w>=4?Math.floor((w-1)/3):0, sw=(w%3===0)?(7+w):0;
    for(let i=0;i<dr;i++) u.push("drone"); for(let i=0;i<ru;i++) u.push("runner");
    for(let i=0;i<br;i++) u.push("brute"); for(let i=0;i<sw;i++) u.push("swarm");
    shuffle(u); for(const t of u) list.push({type:t,gap:gapFor(t)});
  }
  if (list.length) list[0].gap=0.3;
  return list;
}

// ---------- effects ----------
function kick(m){ state.shake=Math.max(state.shake,m); }
function ringPulse(x,z,col){

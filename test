    slots.appendChild(div);
  });
  // inventory
  const inv=$("eq-inv"); inv.innerHTML="";
  if(!save.inventory.length){ inv.innerHTML='<div class="eq-empty">No gear yet. Kill bosses to find loot, or forge with cores.</div>'; return; }
  const sorted=save.inventory.slice().sort((a,b)=>b.rar-a.rar);
  for(const it of sorted){ const R=RARITY[it.rar]; const equipped=save.loadout.includes(it.id);
    const div=document.createElement("div"); div.className="item"+(equipped?" equipped":""); div.style.setProperty("--rc",R.css);
    div.innerHTML='<div class="it-name"><span>'+it.name+'</span><span class="tag">'+R.name+'</span></div>'+
      '<div class="it-stats">'+statLine(it)+'</div>'+
      '<div class="it-actions"><button class="btn up" data-eq="'+it.id+'">'+(equipped?"Equipped":"Equip")+'</button>'+
      '<button class="btn sell" data-sv="'+it.id+'">Salvage ⬡'+R.salvage+'</button></div>';
    inv.appendChild(div);
  }
  inv.querySelectorAll("[data-eq]").forEach(b=>b.addEventListener("click",()=>equipItem(b.dataset.eq)));
  inv.querySelectorAll("[data-sv]").forEach(b=>b.addEventListener("click",()=>salvage(b.dataset.sv)));
}

// ---------- perks ----------
function offerPerk(){
  state.modal="perk"; $("perk-wave").textContent=state.wave;
  const pool=shuffle(PERKS.slice()).slice(0,3); const list=$("perk-list"); list.innerHTML="";
  for(const p of pool){ const div=document.createElement("div"); div.className="perk";
    div.innerHTML='<div class="pi">'+p.i+'</div><div class="pn">'+p.n+'</div><div class="pd">'+p.d+'</div>';
    div.addEventListener("click",()=>choosePerk(p)); list.appendChild(div); }
  $("ov-perk").classList.add("show");
}
function choosePerk(p){ p.apply(state.perk); state.modal=null; $("ov-perk").classList.remove("show");
  toast("Perk: "+p.n); sUp(); if(state.selected) syncPanel(); }

// ---------- waves / control ----------
function startWave(){ if(state.waveActive||state.over) return; resumeAudio();
  state.currentWave=state.wave+1; state.spawnQueue=generateWave(state.currentWave);
  state.spawnIdx=0; state.spawnTimer=state.spawnQueue.length?state.spawnQueue[0].gap:0;
  state.waveActive=true; state.autoTimer=0; state.started=true;
  toast("Wave "+state.currentWave+" incoming"); syncWaveBtn(); }
function gameOver(){ state.over=true; state.waveActive=false; state.placing=null; saveBest();
  $("over-wave").textContent=state.wave; $("over-score").textContent=state.score; $("over-best").textContent=save.best.score;
  $("over-msg").innerHTML = (state.wave>=save.best.wave && state.score>=save.best.score)
    ? 'New record! You held <span class="hi">'+state.wave+' waves</span>.'
    : 'You held <span class="hi">'+state.wave+' waves</span>. Best: '+save.best.wave+'.';
  show("ov-over"); sBoom(); }
function showVictory(){ show("ov-win"); sUp(); }
function show(id){ document.querySelectorAll(".overlay").forEach(o=>o.classList.remove("show")); $(id).classList.add("show"); }
function hideOverlays(){ document.querySelectorAll(".overlay").forEach(o=>o.classList.remove("show")); }

function resetGame(){
  for(const t of towers) scene.remove(t.mesh.group);
  for(const e of enemies) scene.remove(e.mesh.group);
  for(const b of bullets) scene.remove(b.mesh);
  for(const s of shells) scene.remove(s.mesh);
  for(const b of beams) scene.remove(b.mesh);
  for(const f of fxs) scene.remove(f.mesh);
  towers.length=0; enemies.length=0; bullets.length=0; shells.length=0; beams.length=0; fxs.length=0;
  document.querySelectorAll(".fx-float").forEach(n=>n.remove()); floatCount=0;
  state.gold=START_GOLD; state.lives=START_LIVES; state.score=0; state.wave=0; state.currentWave=0;
  state.over=false; state.victoryShown=false; state.waveActive=false; state.spawnIdx=0; state.spawnQueue=[];
  state.autoTimer=0; state.placing=null; state.selected=null; state.paused=false; state.shake=0;
  state.combo=0; state.comboTimer=0; state.modal=null; state.perkWaves=new Set();
  state.ion.cd=0; state.ion.armed=false;
  state.perk={ atkMul:1, rateMul:1, rangeFlat:0, critChance:0, critDmg:0, goldMul:1, slowMul:1, splashMul:1, perTowerDmg:0, surge:false };
  seed=1337; el.combo.classList.remove("show");
  SHARED.ring.visible=false; SHARED.rfill.visible=false; SHARED.hover.visible=false;
  computeEquip(); syncPanel(); syncWaveBtn(); syncAbility(); syncHUD();
}

// ---------- update ----------
let clock=0;
function update(dt){
  clock+=dt;
  // combo decay
  if(state.combo>0){ state.comboTimer-=dt; if(state.comboTimer<=0){ state.combo=0; el.combo.classList.remove("show"); } }
  // ion cd
  if(state.ion.cd>0){ state.ion.cd=Math.max(0,state.ion.cd-dt); }

  // spawner
  if(state.waveActive && state.spawnIdx<state.spawnQueue.length){ state.spawnTimer-=dt;
    while(state.spawnTimer<=0 && state.spawnIdx<state.spawnQueue.length){
      spawnEnemy(state.spawnQueue[state.spawnIdx].type); state.spawnIdx++;
      state.spawnTimer += (state.spawnIdx<state.spawnQueue.length)?state.spawnQueue[state.spawnIdx].gap:0.001; } }

  // enemies
  for(let i=enemies.length-1;i>=0;i--){ const e=enemies[i];
    if(clock>=e.slowUntil) e.slow=1;
    let rem=e.speed*e.slow*dt;
    while(rem>0 && e.wp<waypoints.length){ const tg=waypoints[e.wp];
      const dx=tg.x-e.x, dz=tg.z-e.z, dd=Math.hypot(dx,dz);
      if(dd<=rem){ e.x=tg.x; e.z=tg.z; e.dist+=dd; rem-=dd; e.wp++; }
      else { e.x+=dx/dd*rem; e.z+=dz/dd*rem; e.dist+=rem; rem=0; } }
    // mesh transform
    if(e.hit>0){ e.hit-=dt; }
    const punch=e.hit>0?1.18:1;
    e.mesh.group.position.set(e.x,0,e.z); e.mesh.body.scale.setScalar(punch);
    e.mesh.sring.visible = e.slow<1;
    if(e.shape!=="cone"){ e.mesh.body.rotation.y+=dt*1.5; }
    // hp bar
    const frac=Math.max(0,e.hp/e.maxHp);
    e.mesh.fill.scale.x=Math.max(0.001,frac);
    e.mesh.fill.position.x=-(e.mesh.barW*(1-frac))/2;
    e.mesh.fill.material.color.setHex(frac>0.5?0x4ade80:frac>0.25?0xfbbf24:0xfb6f7a);
    e.mesh.bar.quaternion.copy(camera.quaternion);
    if(e.wp>=waypoints.length){ state.lives-=e.leak; SHARED.coreInner.material.emissiveIntensity=2.2; kick(5); sHurt();
      floatText(corePos.x,corePos.z,1.4,"-"+e.leak,"#fb6f7a",false);
      scene.remove(e.mesh.group); enemies.splice(i,1); syncHUD();
      if(state.lives<=0){ state.lives=0; gameOver(); return; } } }

  // towers
  for(const t of towers){ const d=TOWERS[t.type], s=statsOf(t); t.cd-=dt;
    const target=acquire(t,s.range);
    if(target){ const yaw=Math.atan2(target.x-t.x, target.z-t.z);
      let diff=yaw-t.turret.rotation.y; while(diff>Math.PI)diff-=Math.PI*2; while(diff<-Math.PI)diff+=Math.PI*2;
      t.turret.rotation.y+=diff*Math.min(1,dt*14); }
    if(t.mesh.group.userData.pulse){ t.mesh.group.userData.pulse.scale.setScalar(1+Math.sin(clock*4)*0.12); }
    if(t.cd<=0 && target){ t.cd=1/s.rate;
      const isCrit=critRoll(); let dmg=s.dmg; if(isCrit) dmg*=critMult();
      const tipPos=new THREE.Vector3(); t.tip.getWorldPosition(tipPos);
      if(d.kind==="bullet"){ const m=new THREE.Mesh(SHARED.geo.bullet,new THREE.MeshBasicMaterial({color:d.color}));
        m.position.copy(tipPos); scene.add(m); bullets.push({mesh:m,target,speed:11,dmg,crit:isCrit,life:1.4}); sShoot(); }
      else if(d.kind==="frost"){ beamFx(tipPos,enemyTop(target),d.color,0.14,0.05);
        applySlow(target,s.slow,s.slowDur,clock); hurtEnemy(target,dmg,isCrit); if(Math.random()<0.5) sZap(); }
      else if(d.kind==="shell"){ const m=new THREE.Mesh(SHARED.geo.shell,new THREE.MeshBasicMaterial({color:d.color}));
        m.position.copy(tipPos); scene.add(m);
        shells.push({mesh:m,ox:tipPos.x,oz:tipPos.z,oy:tipPos.y,tx:target.x,tz:target.z,dmg,crit:isCrit,splash:s.splash,t:0,
          dur:Math.max(0.25,Math.hypot(target.x-tipPos.x,target.z-tipPos.z)/7)}); sShoot(); }
      else if(d.kind==="beam"){ beamFx(tipPos,enemyTop(target),d.color,0.16,0.08); hurtEnemy(target,dmg,isCrit);
        explosion(target.x,target.z,0.7,d.color); sRail(); } } }

  // bullets
  for(let i=bullets.length-1;i>=0;i--){ const b=bullets[i]; b.life-=dt;
    const alive=enemies.indexOf(b.target)>=0;
    if(!alive||b.life<=0){ scene.remove(b.mesh); bullets.splice(i,1); continue; }
    const tp=enemyTop(b.target); const dir=tp.clone().sub(b.mesh.position); const dd=dir.length(); const step=b.speed*dt;
    if(dd<=step+b.target.size*0.6){ hurtEnemy(b.target,b.dmg,b.crit); scene.remove(b.mesh); bullets.splice(i,1); }
    else { b.mesh.position.addScaledVector(dir.normalize(),step); } }

  // shells (arc)
  for(let i=shells.length-1;i>=0;i--){ const sh=shells[i]; sh.t+=dt; const p=clamp(sh.t/sh.dur,0,1);
    const x=sh.ox+(sh.tx-sh.ox)*p, z=sh.oz+(sh.tz-sh.oz)*p; const y=sh.oy+Math.sin(p*Math.PI)*1.6;
    sh.mesh.position.set(x,y,z);
    if(p>=1){ explosion(sh.tx,sh.tz,sh.splash,TOWERS.mortar.color); sBoom(); kick(2);
      for(let j=enemies.length-1;j>=0;j--){ const e=enemies[j];
        if(Math.hypot(e.x-sh.tx,e.z-sh.tz)<=sh.splash) hurtEnemy(e,sh.dmg,sh.crit); }
      scene.remove(sh.mesh); shells.splice(i,1); } }

  // beams decay
  for(let i=beams.length-1;i>=0;i--){ const b=beams[i]; b.life-=dt;
    b.mesh.material.opacity=0.9*(b.life/b.max); if(b.life<=0){ scene.remove(b.mesh); beams.splice(i,1); } }

  // fx
  for(let i=fxs.length-1;i>=0;i--){ const f=fxs[i]; f.life-=dt; const a=f.life/f.max;
    if(f.life<=0){ scene.remove(f.mesh); fxs.splice(i,1); continue; }
    if(f.kind==="ring"){ const s=f.s0+(f.s1-f.s0)*(1-a); f.mesh.scale.set(s,s,s); f.mesh.material.opacity=0.8*a; }
    else if(f.kind==="flash"){ const s=f.s0+(f.s1-f.s0)*(1-a); f.mesh.scale.set(s,s,s); f.mesh.material.opacity=0.85*a; }
    else if(f.kind==="spark"){ f.vy-=9*dt; f.mesh.position.x+=f.vx*dt; f.mesh.position.y+=f.vy*dt; f.mesh.position.z+=f.vz*dt;
      f.mesh.material.opacity=a; f.mesh.material.transparent=true; if(f.mesh.position.y<0.05) f.life=Math.min(f.life,0.05); }
    else if(f.kind==="ionbeam"){ f.mesh.material.opacity=0.85*a; f.mesh.scale.x=f.mesh.scale.z=1+(1-a)*0.4; } }

  // core flash decay
  if(SHARED.coreInner.material.emissiveIntensity>1.2) SHARED.coreInner.material.emissiveIntensity=Math.max(1.2,SHARED.coreInner.material.emissiveIntensity-dt*3);

  // wave complete
  if(state.waveActive && state.spawnIdx>=state.spawnQueue.length && enemies.length===0){
    state.waveActive=false; state.wave=state.currentWave; const bonus=waveBonus(state.wave);
    state.gold+=bonus; state.score+=bonus; floatText(corePos.x,corePos.z,1.6,"Wave clear +"+bonus,"#34d399",false);
    if(state.wave%10===0) rollDrop(state.wave,true);
    saveBest(); syncWaveBtn(); syncHUD();
    // perk every 5 waves
    if(state.wave%5===0 && !state.perkWaves.has(state.wave)){ state.perkWaves.add(state.wave); offerPerk(); }
    else if(state.wave===20 && !state.victoryShown){ state.victoryShown=true; showVictory(); }
    else if(state.auto && !state.over){ state.autoTimer=1.6; }
  }
  // auto start
  if(state.auto && !state.waveActive && !state.over && state.started && !state.modal && state.autoTimer>0){
    state.autoTimer-=dt; if(state.autoTimer<=0) startWave(); }
}

function enemyTop(e){ return new THREE.Vector3(e.x, e.size+0.25, e.z); }
function beamFx(a,b,col,life,w){ const m=new THREE.Mesh(SHARED.geo.beam,
  new THREE.MeshBasicMaterial({color:col,transparent:true,opacity:0.9})); m.material.depthWrite=false;
  orientBeam(m,a,b); m.scale.x=w/0.04; m.scale.z=w/0.04; scene.add(m); beams.push({mesh:m,life,max:life}); }

// ---------- render ----------
function render(){
  // core spin + glow pulse
  if(SHARED.core){ SHARED.core.rotation.y+=0.01; SHARED.coreInner.rotation.x+=0.012;
    const g=1+Math.sin(clock*2)*0.08; SHARED.coreGlow.scale.setScalar(g); }
  // camera shake
  if(state.shake>0){ const k=state.shake*0.02;
    camera.position.x+=(Math.random()-0.5)*k; camera.position.y+=(Math.random()-0.5)*k; }
  renderer.render(scene,camera);
}

// ---------- input: camera + raycast ----------
const pointers=new Map(); let dragging=false, downX=0, downY=0, pinchDist=0;
function ndc(clientX,clientY){ const r=renderer.domElement.getBoundingClientRect();
  return { x:((clientX-r.left)/r.width)*2-1, y:-((clientY-r.top)/r.height)*2+1 }; }
function groundHit(clientX,clientY){
  const n=ndc(clientX,clientY); raycaster.setFromCamera(n,camera);
  // intersect y=0.06 plane analytically
  const o=raycaster.ray.origin, d=raycaster.ray.direction;
  if(Math.abs(d.y)<1e-6) return null; const tt=(0.06-o.y)/d.y; if(tt<0) return null;
  return { x:o.x+d.x*tt, z:o.z+d.z*tt };
}
sceneEl.addEventListener("pointerdown", ev=>{ sceneEl.setPointerCapture(ev.pointerId);
  pointers.set(ev.pointerId,{x:ev.clientX,y:ev.clientY}); resumeAudio();
  if(pointers.size===1){ dragging=false; downX=ev.clientX; downY=ev.clientY; }
  else if(pointers.size===2){ const p=[...pointers.values()]; pinchDist=Math.hypot(p[0].x-p[1].x,p[0].y-p[1].y); } });
sceneEl.addEventListener("pointermove", ev=>{
  const prev=pointers.get(ev.pointerId); if(prev){ prev.x=ev.clientX; prev.y=ev.clientY; }
  if(pointers.size===2){ const p=[...pointers.values()]; const d=Math.hypot(p[0].x-p[1].x,p[0].y-p[1].y);
    if(pinchDist){ camDist=clamp(camDist*(pinchDist/d),9,30); updateCamera(); } pinchDist=d; dragging=true; return; }
  if(pointers.size===1 && (ev.buttons&1)){
    const dx=ev.clientX-downX, dy=ev.clientY-downY;
    if(!dragging && Math.hypot(dx,dy)>6) dragging=true;
    if(dragging){ camAzim-=dx*0.005; camPolar=clamp(camPolar+dy*0.004,0.22,1.25); updateCamera(); downX=ev.clientX; downY=ev.clientY; }
  } else if(pointers.size<=1){ // hover preview
    const h=groundHit(ev.clientX,ev.clientY); updateHover(h);
  } });
function endPointer(ev){ pointers.delete(ev.pointerId); if(pointers.size<2) pinchDist=0;
  if(pointers.size===0 && !dragging){ handleClick(ev.clientX,ev.clientY); } dragging=false; }
sceneEl.addEventListener("pointerup", endPointer);
sceneEl.addEventListener("pointercancel", ev=>{ pointers.delete(ev.pointerId); });
sceneEl.addEventListener("pointerleave", ()=>{ if(pointers.size===0){ SHARED.hover.visible=false; if(!state.selected){ SHARED.ring.visible=false; SHARED.rfill.visible=false; } } });
sceneEl.addEventListener("wheel", ev=>{ ev.preventDefault(); camDist=clamp(camDist+ev.deltaY*0.012,9,30); updateCamera(); }, {passive:false});
sceneEl.addEventListener("contextmenu", ev=>{ ev.preventDefault(); cancelPlace(); state.ion.armed=false; syncAbility(); });

function updateHover(h){
  if(state.over || (!state.placing && !state.ion.armed)){ SHARED.hover.visible=false;
    if(!state.selected){ SHARED.ring.visible=false; SHARED.rfill.visible=false; } return; }
  if(!h){ SHARED.hover.visible=false; return; }
  const c=tileC(h.x), r=tileR(h.z);
  if(c<0||r<0||c>=COLS||r>=ROWS){ SHARED.hover.visible=false; return; }
  if(state.ion.armed){ // show ion target ring
    SHARED.hover.visible=false; SHARED.ring.visible=true; SHARED.rfill.visible=true;
    SHARED.ring.position.set(h.x,0.12,h.z); SHARED.rfill.position.set(h.x,0.07,h.z);
    SHARED.ring.scale.setScalar(2.3); SHARED.rfill.scale.setScalar(2.3);
    setRingColor(0xb483ff); return; }
  // placing
  const ok=tileFree(c,r) && state.gold>=TOWERS[state.placing].cost;
  SHARED.hover.visible=true; SHARED.hover.position.set(wx(c),0.1,wz(r));
  SHARED.hover.material.color.setHex(ok?0x38bdf8:0xfb6f7a);
  const s=statsOf({type:state.placing,level:1});
  SHARED.ring.visible=true; SHARED.rfill.visible=true;
  SHARED.ring.position.set(wx(c),0.12,wz(r)); SHARED.rfill.position.set(wx(c),0.07,wz(r));
  SHARED.ring.scale.setScalar(s.range); SHARED.rfill.scale.setScalar(s.range);
  setRingColor(ok?TOWERS[state.placing].color:0xfb6f7a);
}
function setRingColor(hex){ SHARED.ring.material.color.setHex(hex); SHARED.rfill.material.color.setHex(hex); }

function handleClick(clientX,clientY){
  if(state.over||state.modal) return;
  const h=groundHit(clientX,clientY); if(!h) return;
  const c=tileC(h.x), r=tileR(h.z);
  if(state.ion.armed){ if(ionReady()) fireIon(h.x,h.z); else { state.ion.armed=false; syncAbility(); } updateHover(h); return; }
  if(state.placing){ place(c,r); updateHover(h); return; }
  const tw=towers.find(o=>o.c===c&&o.r===r);
  if(tw){ state.selected=tw; const s=statsOf(tw);
    SHARED.ring.visible=true; SHARED.rfill.visible=true; SHARED.ring.position.set(tw.x,0.12,tw.z); SHARED.rfill.position.set(tw.x,0.07,tw.z);
    SHARED.ring.scale.setScalar(s.range); SHARED.rfill.scale.setScalar(s.range); setRingColor(TOWERS[tw.type].color); syncPanel(); }
  else { state.selected=null; SHARED.ring.visible=false; SHARED.rfill.visible=false; syncPanel(); }
}

// ---------- buttons ----------
el.btnWave.addEventListener("click", startWave);
$("btn-begin").addEventListener("click", ()=>{ resumeAudio(); state.started=true; hideOverlays(); });
$("btn-restart").addEventListener("click", ()=>{ resetGame(); state.started=true; hideOverlays(); });
$("btn-continue").addEventListener("click", ()=>{ state.modal=null; hideOverlays(); if(state.auto) state.autoTimer=1.4; });
el.pcUp.addEventListener("click", ()=>{ if(state.selected) upgrade(state.selected); });
el.pcSell.addEventListener("click", ()=>{ if(state.selected) sell(state.selected); });
el.btnPause.addEventListener("click", togglePause);
function togglePause(){ state.paused=!state.paused; el.btnPause.textContent=state.paused?"▶":"⏸"; el.btnPause.classList.toggle("on",state.paused); }
el.btnSpeed.addEventListener("click", ()=>{ state.speed=state.speed===1?2:state.speed===2?3:1; el.btnSpeed.textContent=state.speed+"×"; el.btnSpeed.classList.toggle("on",state.speed>1); });
el.btnAuto.addEventListener("click", ()=>{ state.auto=!state.auto; el.btnAuto.classList.toggle("on",state.auto); if(!state.auto) state.autoTimer=0; });
el.btnMute.addEventListener("click", ()=>{ state.muted=!state.muted; el.btnMute.textContent=state.muted?"🔇":"🔊"; });
el.ability.addEventListener("click", ()=>{ resumeAudio(); if(!ionReady()) return;
  state.ion.armed=!state.ion.armed; if(state.ion.armed) state.placing=null; syncShop(); syncAbility(); });
$("open-eq").addEventListener("click", openEq);
$("eq-close").addEventListener("click", closeEq);
$("eq-forge").addEventListener("click", forge);

function resumeAudio(){ const ac=audio(); if(ac&&ac.state==="suspended"){ try{ac.resume();}catch(e){} } }

window.addEventListener("keydown", ev=>{ if(ev.repeat) return; const k=ev.key.toLowerCase();
  if(k==="e"){ if(state.modal==="eq") closeEq(); else if(!state.modal){ openEq(); } return; }
  if(k===" "){ ev.preventDefault(); if(!state.started){ state.started=true; hideOverlays(); return; }
    if(state.modal) return; if(!state.waveActive&&!state.over) startWave(); else togglePause(); return; }
  if(k==="escape"){ if(state.modal==="eq"){ closeEq(); return; } if(state.ion.armed){ state.ion.armed=false; syncAbility(); return; }
    if(state.placing) cancelPlace(); else { state.selected=null; SHARED.ring.visible=false; SHARED.rfill.visible=false; syncPanel(); } return; }
  if(k==="q"){ if(ionReady()&&!state.modal){ state.ion.armed=!state.ion.armed; if(state.ion.armed) state.placing=null; syncShop(); syncAbility(); } return; }
  if(state.modal) return;
  for(const key of TOWER_ORDER){ if(TOWERS[key].key===k){ armTower(key); return; } }
  if(k==="u"&&state.selected) upgrade(state.selected);
  if(k==="s"&&state.selected) sell(state.selected);
});

// ---------- persistence ----------
function loadSave(){
  let s=null; try{ s=JSON.parse(localStorage.getItem("neonBastion3D")||"null"); }catch(e){}
  if(!s||typeof s!=="object") s={};
  s.best = s.best && typeof s.best.wave==="number" ? s.best : { wave:0, score:0 };
  s.cores = typeof s.cores==="number" ? s.cores : 0;
  s.inventory = Array.isArray(s.inventory) ? s.inventory : [];
  s.loadout = Array.isArray(s.loadout)&&s.loadout.length===3 ? s.loadout : [null,null,null];
  s.nextId = typeof s.nextId==="number" ? s.nextId : 1;
  if(!s.seeded){ const it=generateItem(0); s.inventory.push(it); s.loadout[0]=it.id; s.seeded=true; }
  return s;
}
function persist(){ try{ localStorage.setItem("neonBastion3D", JSON.stringify(save)); }catch(e){} }
function saveBest(){ if(state.wave>save.best.wave||(state.wave===save.best.wave&&state.score>save.best.score)){
  save.best={wave:state.wave,score:state.score}; persist(); } }

// ---------- main loop ----------
let lastT=performance.now();
function frame(t){ let raw=(t-lastT)/1000; lastT=t; raw=Math.min(raw,0.05);
  if(state.started&&!state.paused&&!state.over&&!state.modal){ let total=raw*state.speed;
    while(total>0){ const d=Math.min(total,0.025); update(d); total-=d; } }
  updateCamera(); render(); syncAbility();
  requestAnimationFrame(frame);
}

// ---------- boot ----------
initThree();
buildShop();
computeEquip();
syncHUD();
syncWaveBtn();
syncAbility();
requestAnimationFrame(frame);

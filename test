}
function explosion(x,z,radius,col){
  const flash=new THREE.Mesh(SHARED.geo.flash, new THREE.MeshBasicMaterial({color:col,transparent:true,opacity:0.85}));
  flash.position.set(x,0.4,z); flash.scale.setScalar(radius*0.4); scene.add(flash);

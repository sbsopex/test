// ---- Three.js setup ----
let renderer, scene, camera, raycaster, groundPlane;
let camAzim = 0.62, camPolar = 0.66, camDist = 18;
const camTarget = new THREE.Vector3(0, 0, 0.4);
const SHARED = {};

function initThree(){
  scene = new THREE.Scene();
  scene.background = new THREE.Color(0x0a1124);
  scene.fog = new THREE.Fog(0x0a1124, 22, 46);

  camera = new THREE.PerspectiveCamera(45, 1.5, 0.1, 200);
  renderer = new THREE.WebGLRenderer({ antialias:true });
  renderer.setPixelRatio(Math.min(2, window.devicePixelRatio||1));
  if ("outputColorSpace" in renderer) renderer.outputColorSpace = THREE.SRGBColorSpace;
  renderer.shadowMap.enabled = true;
  renderer.shadowMap.type = THREE.PCFSoftShadowMap;
  sceneEl.appendChild(renderer.domElement);

  // lights
  scene.add(new THREE.HemisphereLight(0x9fc2ff, 0x0a1024, 0.55));
  const amb = new THREE.AmbientLight(0x4060a0, 0.4); scene.add(amb);
  const dir = new THREE.DirectionalLight(0xcfe2ff, 1.15);
  dir.position.set(7, 16, 6); dir.castShadow = true;
  dir.shadow.mapSize.set(2048, 2048);
  const sc = dir.shadow.camera; sc.left=-11; sc.right=11; sc.top=9; sc.bottom=-9; sc.near=1; sc.far=44;
  dir.shadow.bias = -0.0006; scene.add(dir);
  const rim = new THREE.DirectionalLight(0x7a52ff, 0.4); rim.position.set(-8, 6, -7); scene.add(rim);

  buildBoard();

  raycaster = new THREE.Raycaster();
  // invisible math plane for raycasts handled analytically; also keep ground mesh
  resize();
  updateCamera();
}

function buildBoard(){
  // base slab
  const slab = new THREE.Mesh(
    new THREE.BoxGeometry(COLS+0.6, 0.5, ROWS+0.6),
    new THREE.MeshStandardMaterial({ color:0x0c1530, roughness:0.95, metalness:0.1 })
  );
  slab.position.y = -0.3; slab.receiveShadow = true; scene.add(slab);

  // ground plane for raycasting (flat, y=0.06)
  groundPlane = new THREE.Mesh(
    new THREE.PlaneGeometry(COLS, ROWS),
    new THREE.MeshStandardMaterial({ color:0x0e1a36, roughness:1, metalness:0 })
  );
  groundPlane.rotation.x = -Math.PI/2; groundPlane.position.y = 0.04; groundPlane.receiveShadow = true;
  scene.add(groundPlane);

  // shared tile geometry/materials
  const tileGeo = new THREE.BoxGeometry(0.92, 0.12, 0.92);
  const buildMat = new THREE.MeshStandardMaterial({ color:0x16264a, roughness:0.8, metalness:0.15, emissive:0x0a1530, emissiveIntensity:0.4 });
  const pathMat  = new THREE.MeshStandardMaterial({ color:0x223764, roughness:0.6, metalness:0.2, emissive:0x1b3a78, emissiveIntensity:0.5 });

  for (let r=0;r<ROWS;r++) for (let c=0;c<COLS;c++){
    const onPath = pathSet.has(c+","+r);
    const m = new THREE.Mesh(tileGeo, onPath ? pathMat : buildMat);
    m.position.set(wx(c), onPath?0.03:0.08, wz(r));
    m.receiveShadow = true; if (!onPath) m.castShadow = false;
    scene.add(m);
  }

  // path edge glow strip via thin emissive boxes already covered; add flowing markers using small cones? keep simple.

  // hover highlight
  const hov = new THREE.Mesh(new THREE.BoxGeometry(0.92,0.16,0.92),
    new THREE.MeshBasicMaterial({ color:0x38bdf8, transparent:true, opacity:0.25 }));
  hov.position.y = 0.1; hov.visible = false; scene.add(hov);
  SHARED.hover = hov;

  // range ring (shown when placing / selected)
  const ring = new THREE.Mesh(new THREE.RingGeometry(0.98, 1.0, 48),
    new THREE.MeshBasicMaterial({ color:0x38bdf8, transparent:true, opacity:0.65, side:THREE.DoubleSide }));
  ring.rotation.x = -Math.PI/2; ring.position.y = 0.12; ring.visible = false; scene.add(ring);
  const rfill = new THREE.Mesh(new THREE.CircleGeometry(1, 48),
    new THREE.MeshBasicMaterial({ color:0x38bdf8, transparent:true, opacity:0.07, side:THREE.DoubleSide }));
  rfill.rotation.x = -Math.PI/2; rfill.position.y = 0.07; rfill.visible = false; scene.add(rfill);
  SHARED.ring = ring; SHARED.rfill = rfill;

  // core
  const core = new THREE.Group();
  const coreInner = new THREE.Mesh(new THREE.IcosahedronGeometry(0.42, 0),
    new THREE.MeshStandardMaterial({ color:0x7fd4ff, emissive:0x38bdf8, emissiveIntensity:1.2, roughness:0.3 }));
  coreInner.castShadow = true; core.add(coreInner);
  const coreGlow = new THREE.Mesh(new THREE.SphereGeometry(0.7, 16, 16),
    new THREE.MeshBasicMaterial({ color:0x38bdf8, transparent:true, opacity:0.18 }));
  core.add(coreGlow);
  core.position.set(corePos.x, 0.55, corePos.z); scene.add(core);
  SHARED.core = core; SHARED.coreInner = coreInner; SHARED.coreGlow = coreGlow;

  // shared geometries for reuse
  SHARED.geo = {
    bullet: new THREE.SphereGeometry(0.09, 8, 8),
    shell:  new THREE.SphereGeometry(0.12, 8, 8),
    beam:   new THREE.CylinderGeometry(0.04, 0.04, 1, 6),
    spark:  new THREE.BoxGeometry(0.09,0.09,0.09),
    flash:  new THREE.SphereGeometry(1, 12, 12),
    ringfx: new THREE.RingGeometry(0.6, 0.85, 24),
  };
}

function updateCamera(){
  const sp = Math.sin(camPolar), cp = Math.cos(camPolar);
  camera.position.set(
    camTarget.x + camDist*sp*Math.sin(camAzim),
    camTarget.y + camDist*cp,
    camTarget.z + camDist*sp*Math.cos(camAzim)
  );
  camera.lookAt(camTarget);
}

function resize(){
  const w = sceneEl.clientWidth, h = sceneEl.clientHeight || (w*ROWS/COLS);
  renderer.setSize(w, h, false);
  camera.aspect = w/Math.max(1,h); camera.updateProjectionMatrix();
}
window.addEventListener("resize", ()=>{ if(renderer) resize(); });

// ---------- meshes ----------
function makeTowerMesh(type){
  const d = TOWERS[type], col = d.color;
  const g = new THREE.Group();
  const baseMat = new THREE.MeshStandardMaterial({ color:0x111c36, roughness:0.6, metalness:0.4 });
  const accent = new THREE.MeshStandardMaterial({ color:col, emissive:col, emissiveIntensity:0.5, roughness:0.4, metalness:0.3 });
  // pedestal
  const ped = new THREE.Mesh(new THREE.CylinderGeometry(0.34,0.4,0.3,12), baseMat);
  ped.position.y=0.15; ped.castShadow=true; ped.receiveShadow=true; g.add(ped);
  const ringB = new THREE.Mesh(new THREE.TorusGeometry(0.34,0.04,8,18), accent);
  ringB.rotation.x=Math.PI/2; ringB.position.y=0.3; g.add(ringB);

  const turret = new THREE.Group(); turret.position.y=0.34; g.add(turret);
  const tip = new THREE.Object3D();

  if (type==="gun"){
    const body=new THREE.Mesh(new THREE.SphereGeometry(0.24,12,12), baseMat); body.castShadow=true; turret.add(body);
    const barrel=new THREE.Mesh(new THREE.BoxGeometry(0.1,0.1,0.5), accent); barrel.position.set(0,0.02,0.3); barrel.castShadow=true; turret.add(barrel);
    tip.position.set(0,0.36,0.55);
  } else if (type==="frost"){
    const body=new THREE.Mesh(new THREE.OctahedronGeometry(0.28,0), accent); body.position.y=0.05; body.castShadow=true; turret.add(body);
    const ringE=new THREE.Mesh(new THREE.TorusGeometry(0.3,0.03,8,18),
      new THREE.MeshBasicMaterial({color:col,transparent:true,opacity:0.7})); ringE.rotation.x=Math.PI/2; ringE.position.y=0.05; turret.add(ringE);
    g.userData.pulse = ringE; tip.position.set(0,0.4,0);
  } else if (type==="mortar"){
    const body=new THREE.Mesh(new THREE.BoxGeometry(0.42,0.26,0.42), baseMat); body.position.y=0.04; body.castShadow=true; turret.add(body);
    const tube=new THREE.Mesh(new THREE.CylinderGeometry(0.13,0.15,0.4,12), accent); tube.position.set(0,0.18,0.12); tube.rotation.x=-0.5; tube.castShadow=true; turret.add(tube);
    tip.position.set(0,0.42,0.28);
  } else { // rail
    const body=new THREE.Mesh(new THREE.BoxGeometry(0.3,0.18,0.34), baseMat); body.position.y=0.04; body.castShadow=true; turret.add(body);
    const barrel=new THREE.Mesh(new THREE.CylinderGeometry(0.05,0.05,0.85,8), accent); barrel.rotation.x=Math.PI/2; barrel.position.set(0,0.08,0.42); barrel.castShadow=true; turret.add(barrel);
    const fin=new THREE.Mesh(new THREE.BoxGeometry(0.02,0.18,0.4),
      new THREE.MeshBasicMaterial({color:col})); fin.position.set(0,0.18,0.1); turret.add(fin);
    tip.position.set(0,0.42,0.85);
  }
  turret.add(tip);
  // level pips
  const pips=new THREE.Group(); pips.position.y=0.02; g.add(pips); g.userData.pips=pips; g.userData.pipMat=accent;
  return { group:g, turret, tip };
}

function setPips(t){
  const grp = t.mesh.group, pips = grp.userData.pips;
  while(pips.children.length) pips.remove(pips.children[0]);
  for (let i=0;i<t.level;i++){
    const p=new THREE.Mesh(new THREE.SphereGeometry(0.05,6,6), grp.userData.pipMat);
    p.position.set(-0.14+i*0.14, 0.04, -0.32); pips.add(p);
  }
}

function makeEnemyMesh(type){
  const d = ENEMIES[type], col = d.color;
  const grp = new THREE.Group();
  const mat = new THREE.MeshStandardMaterial({ color:col, roughness:0.5, metalness:0.3, emissive:col, emissiveIntensity:0.18 });
  let body;
  if (d.shape==="sphere") body=new THREE.Mesh(new THREE.SphereGeometry(d.size,14,14), mat);
  else if (d.shape==="cone") body=new THREE.Mesh(new THREE.ConeGeometry(d.size,d.size*1.8,14), mat);
  else if (d.shape==="box") body=new THREE.Mesh(new THREE.BoxGeometry(d.size*1.6,d.size*1.6,d.size*1.6), mat);
  else body=new THREE.Mesh(new THREE.IcosahedronGeometry(d.size,0), mat);
  body.castShadow=true; body.position.y = d.size + 0.12; grp.add(body);
  if (d.shape==="cone") body.rotation.x = Math.PI; // tip forward look
  if (d.boss){ const aura=new THREE.Mesh(new THREE.SphereGeometry(d.size*1.7,16,16),
    new THREE.MeshBasicMaterial({color:col,transparent:true,opacity:0.16})); aura.position.y=body.position.y; grp.add(aura); }

  // slow ring
  const sring=new THREE.Mesh(new THREE.TorusGeometry(d.size+0.12,0.04,8,16),
    new THREE.MeshBasicMaterial({color:0x7fd4ff,transparent:true,opacity:0.85}));
  sring.rotation.x=Math.PI/2; sring.position.y=0.1; sring.visible=false; grp.add(sring);

  // hp bar (billboard)
  const bar=new THREE.Group(); bar.position.y = body.position.y + d.size + 0.22;
  const bw = Math.max(0.5, d.size*2.6);
  const bg=new THREE.Mesh(new THREE.PlaneGeometry(bw,0.08), new THREE.MeshBasicMaterial({color:0x05080f}));
  const fill=new THREE.Mesh(new THREE.PlaneGeometry(bw,0.08), new THREE.MeshBasicMaterial({color:0x4ade80}));
  fill.position.z=0.001; bar.add(bg); bar.add(fill); grp.add(bar);
  return { group:grp, body, sring, bar, fill, barW:bw };
}

// orient a cylinder beam mesh between two world points
function orientBeam(mesh, a, b){
  const dir = new THREE.Vector3().subVectors(b,a); const len = dir.length();
  mesh.position.copy(a).addScaledVector(dir, 0.5);
  mesh.scale.set(1, Math.max(0.001,len), 1);
  if (len>0.0001) mesh.quaternion.setFromUnitVectors(new THREE.Vector3(0,1,0), dir.clone().normalize());
}


// ---------- equipment modal render ----------
function openEq(){ state.modal="eq"; renderEq(); $("ov-eq").classList.add("show"); }
function closeEq(){ state.modal=null; $("ov-eq").classList.remove("show"); }
function renderEq(){
  $("eq-cores").textContent="⬡ "+save.cores+" cores"; $("eq-forge").textContent="⬡ Forge item · 80";
  $("eq-forge").disabled = save.cores<80;

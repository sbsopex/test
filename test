<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
<title>NEON BASTION 3D — Tower Defense</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@500;600;700&display=swap" rel="stylesheet" />
<style>
  :root{
    --bg0:#070a14; --bg1:#0e1730; --panel:#101a32; --panel2:#0b1326; --line:#1f2c4d;
    --text:#e8eefb; --muted:#90a0c2; --muted2:#5a6a8f;
    --cyan:#38bdf8; --amber:#fbbf24; --orange:#fb7c3f; --violet:#b483ff;
    --green:#4ade80; --red:#fb6f7a; --gold:#fcd34d; --good:#34d399;
    --t-gun:#fbbf24; --t-frost:#38bdf8; --t-mortar:#fb7c3f; --t-rail:#b483ff;
    --r0:#9aa7c4; --r1:#4aa3ff; --r2:#b06bff; --r3:#ffb13b;
    --font:"Chakra Petch", ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
    --mono:ui-monospace, "SF Mono", "JetBrains Mono", Menlo, Consolas, monospace;
  }
  *{ box-sizing:border-box; }
  html,body{ margin:0; height:100%; }
  body{
    background:
      radial-gradient(1200px 700px at 18% -10%, #16264e 0%, transparent 55%),
      radial-gradient(1000px 600px at 112% 120%, #1a1140 0%, transparent 55%),
      linear-gradient(180deg, var(--bg1), var(--bg0));
    color:var(--text); font-family:var(--font); -webkit-font-smoothing:antialiased;
    min-height:100%; padding:16px 14px 26px; user-select:none; -webkit-user-select:none; overflow-x:hidden;
  }
  #app{ max-width:1180px; margin:0 auto; }

  header{ display:flex; align-items:center; gap:12px 16px; flex-wrap:wrap; margin-bottom:12px; }
  .brand{ display:flex; align-items:center; gap:11px; margin-right:auto; }
  .logo{ width:34px; height:34px; border-radius:9px; position:relative; flex:none;
    background:linear-gradient(135deg, var(--cyan), var(--violet));
    box-shadow:0 0 18px rgba(56,189,248,.45), inset 0 0 10px rgba(255,255,255,.25); }
  .logo::after{ content:""; position:absolute; inset:8px; border:2px solid rgba(7,10,20,.85); border-radius:5px; }
  .title{ font-weight:700; font-size:19px; letter-spacing:3px; line-height:1;
    background:linear-gradient(90deg, var(--cyan), #c9b6ff); -webkit-background-clip:text; background-clip:text; color:transparent; }
  .subtitle{ font-size:10px; letter-spacing:3px; color:var(--muted2); text-transform:uppercase; margin-top:3px; }

  .stats{ display:flex; gap:8px; flex-wrap:wrap; }
  .chip{ display:flex; align-items:center; gap:8px; background:linear-gradient(180deg, var(--panel), var(--panel2));
    border:1px solid var(--line); border-radius:11px; padding:6px 11px; }
  .chip .k{ font-size:9px; letter-spacing:1.4px; color:var(--muted2); text-transform:uppercase; }
  .chip .v{ font-size:16px; font-weight:700; font-variant-numeric:tabular-nums; line-height:1; }
  .chip .ic{ font-size:14px; line-height:1; }
  .chip.wave .v{ color:var(--cyan); } .chip.lives .v{ color:var(--red); }
  .chip.gold .v{ color:var(--gold); } .chip.score .v{ color:var(--text); } .chip.cores .v{ color:var(--violet); }

  .stage{ display:grid; grid-template-columns:1fr 290px; gap:14px; align-items:start; }
  .board-wrap{ position:relative; border-radius:14px; overflow:hidden; border:1px solid var(--line);
    background:radial-gradient(800px 500px at 50% 0%, #14213f, #080d1c);
    box-shadow:0 24px 60px -26px rgba(0,0,0,.85), inset 0 0 0 1px rgba(255,255,255,.02); }
  #scene{ width:100%; aspect-ratio:15/10; display:block; touch-action:none; cursor:crosshair; }
  #scene canvas{ display:block; width:100% !important; height:100% !important; }

  .controls{ position:absolute; left:10px; bottom:10px; display:flex; gap:7px; align-items:center; flex-wrap:wrap; z-index:3; }
  .btn{ font-family:var(--font); font-weight:600; letter-spacing:.4px; color:var(--text);
    background:linear-gradient(180deg,#18233f,#111a30); border:1px solid var(--line); border-radius:10px;
    padding:8px 12px; cursor:pointer; font-size:12.5px; transition:transform .07s, border-color .15s, background .15s; }
  .btn:hover{ border-color:#33457a; transform:translateY(-1px); } .btn:active{ transform:translateY(0); }
  .btn:focus-visible{ outline:2px solid var(--cyan); outline-offset:2px; }
  .btn.primary{ background:linear-gradient(180deg, #2aa9e6, #2563c9); border-color:#56c5ff;
    box-shadow:0 8px 22px -10px rgba(56,189,248,.8); color:#fff; }
  .btn.primary.flash{ animation:pulse 1.1s ease-in-out infinite; }
  @keyframes pulse{ 50%{ box-shadow:0 10px 30px -8px rgba(56,189,248,1); transform:translateY(-1px);} }
  .btn.icon{ padding:8px 10px; min-width:40px; }
  .btn.on{ border-color:var(--cyan); color:var(--cyan); }
  .btn:disabled{ opacity:.4; cursor:not-allowed; transform:none; }

  .cam-hint{ position:absolute; right:10px; bottom:10px; z-index:3; font-size:10.5px; color:var(--muted2);
    background:rgba(8,13,28,.6); border:1px solid var(--line); border-radius:8px; padding:6px 9px; letter-spacing:.3px; }
  .cam-hint kbd{ font-family:var(--mono); color:var(--muted); }

  /* combo */
  .combo{ position:absolute; top:10px; left:10px; z-index:3; display:none; align-items:center; gap:8px;
    background:linear-gradient(180deg,#1a2542,#101a30); border:1px solid var(--line); border-radius:10px; padding:6px 11px; }
  .combo.show{ display:flex; }
  .combo .n{ font-size:18px; font-weight:700; color:var(--amber); font-variant-numeric:tabular-nums; }
  .combo .x{ font-size:10px; color:var(--muted2); letter-spacing:1px; text-transform:uppercase; }
  .combo .mult{ font-size:12px; color:var(--good); font-weight:700; }
  .combo.big .n{ animation:pop .25s ease; }
  @keyframes pop{ 0%{ transform:scale(1.5);} 100%{ transform:scale(1);} }

  /* sidebar */
  .sidebar{ background:linear-gradient(180deg, var(--panel), var(--panel2)); border:1px solid var(--line);
    border-radius:14px; padding:13px; }
  .sec-h{ font-size:10px; letter-spacing:2.4px; color:var(--muted2); text-transform:uppercase; margin:2px 0 9px;
    display:flex; align-items:center; justify-content:space-between; }
  .sec-h .mini{ font-size:10px; color:var(--violet); letter-spacing:1px; cursor:pointer; }
  .shop{ display:grid; grid-template-columns:1fr 1fr; gap:8px; }
  .tower-card{ text-align:left; cursor:pointer; background:linear-gradient(180deg,#13203b,#0d1830);
    border:1px solid var(--line); border-radius:11px; padding:9px; position:relative; overflow:hidden;
    transition:transform .08s, border-color .15s, box-shadow .15s; }
  .tower-card::before{ content:""; position:absolute; left:0; top:0; bottom:0; width:3px; background:var(--accent); }
  .tower-card:hover{ transform:translateY(-2px); border-color:#2c3d6e; }
  .tower-card.armed{ border-color:var(--accent); box-shadow:0 0 0 1px var(--accent); }
  .tower-card.cant{ opacity:.45; }
  .tc-top{ display:flex; align-items:center; gap:7px; margin-bottom:6px; }
  .tc-ic{ width:28px; height:28px; flex:none; display:grid; place-items:center; background:rgba(255,255,255,.04); border-radius:8px; }
  .tc-name{ font-size:12.5px; font-weight:700; line-height:1.05; }
  .tc-role{ font-size:8.5px; color:var(--muted2); letter-spacing:1px; text-transform:uppercase; }
  .tc-cost{ margin-left:auto; font-weight:700; color:var(--gold); font-size:13px; font-variant-numeric:tabular-nums; }
  .tc-stats{ display:flex; gap:8px; font-size:10px; color:var(--muted); }
  .tc-stats b{ color:var(--text); font-weight:600; }

  /* ability */
  .ability{ margin-top:11px; width:100%; position:relative; overflow:hidden; text-align:left;
    background:linear-gradient(180deg,#1c1640,#120c2e); border:1px solid #3a2a6e; border-radius:12px; padding:11px 12px; cursor:pointer; }
  .ability:hover{ border-color:#5a3fae; }
  .ability.ready{ box-shadow:0 0 0 1px #7a52ff, 0 8px 22px -12px #7a52ff; }
  .ability.armed{ box-shadow:0 0 0 2px var(--violet); }
  .ability:disabled{ cursor:not-allowed; }
  .ab-fill{ position:absolute; left:0; bottom:0; top:0; background:rgba(180,131,255,.16); width:0%; transition:width .1s linear; }
  .ab-row{ position:relative; display:flex; align-items:center; gap:9px; }
  .ab-ic{ font-size:18px; } .ab-name{ font-weight:700; font-size:13px; color:#d6c9ff; }
  .ab-sub{ font-size:9.5px; color:var(--muted2); letter-spacing:.5px; }
  .ab-cd{ margin-left:auto; font-size:13px; font-weight:700; color:#cbb6ff; font-variant-numeric:tabular-nums; }

  .panel-card{ margin-top:11px; background:linear-gradient(180deg,#13203b,#0d1830);
    border:1px solid var(--line); border-radius:12px; padding:11px; display:none; }
  .panel-card.show{ display:block; }
  .pc-head{ display:flex; align-items:center; gap:8px; margin-bottom:8px; }
  .pc-name{ font-size:13.5px; font-weight:700; }
  .pc-lvl{ margin-left:auto; font-size:9.5px; letter-spacing:1px; color:var(--bg0); background:var(--accent); padding:3px 8px; border-radius:99px; font-weight:700; }
  .pc-grid{ display:grid; grid-template-columns:1fr 1fr; gap:5px 12px; font-size:10.5px; color:var(--muted); margin-bottom:10px; }
  .pc-grid b{ color:var(--text); font-variant-numeric:tabular-nums; }
  .pc-actions{ display:flex; gap:7px; }
  .pc-actions .btn{ flex:1; text-align:center; }
  .btn.sell{ border-color:#5a2a3a; color:#ff9fb0; } .btn.up{ border-color:#2f5a3f; color:#9be8b8; }

  .legend{ margin-top:11px; border-top:1px solid var(--line); padding-top:10px; font-size:10.5px; color:var(--muted); line-height:1.5; }
  .legend b{ color:var(--text); }
  .legend .row{ display:flex; gap:7px; align-items:center; margin-top:4px; }
  .dot{ width:9px; height:9px; border-radius:99px; flex:none; }

  /* overlays */
  .overlay{ position:absolute; inset:0; display:none; place-items:center; text-align:center; z-index:10;
    background:radial-gradient(700px 420px at 50% 40%, rgba(11,18,40,.88), rgba(5,8,18,.97)); backdrop-filter:blur(3px); }
  .overlay.show{ display:grid; }
  .ov-card{ max-width:480px; padding:24px 26px; }
  .ov-kicker{ font-size:11px; letter-spacing:4px; color:var(--cyan); text-transform:uppercase; }
  .ov-title{ font-size:29px; font-weight:700; letter-spacing:2px; margin:8px 0 10px;
    background:linear-gradient(90deg,var(--cyan),#cbb6ff); -webkit-background-clip:text; background-clip:text; color:transparent; }
  .ov-title.lose{ background:linear-gradient(90deg,#ff8a93,#ffd27a); -webkit-background-clip:text; background-clip:text; color:transparent; }
  .ov-title.win{ background:linear-gradient(90deg,#7df0c0,#9fd2ff); -webkit-background-clip:text; background-clip:text; color:transparent; }
  .ov-text{ color:var(--muted); font-size:13px; line-height:1.6; margin-bottom:16px; }
  .ov-text .hi{ color:var(--text); font-weight:600; }
  .ov-stats{ display:flex; gap:9px; justify-content:center; margin:0 0 16px; flex-wrap:wrap; }
  .ov-stat{ background:linear-gradient(180deg,#13203b,#0d1830); border:1px solid var(--line); border-radius:10px; padding:8px 13px; }
  .ov-stat .k{ font-size:9px; letter-spacing:1.4px; color:var(--muted2); text-transform:uppercase; }
  .ov-stat .v{ font-size:19px; font-weight:700; font-variant-numeric:tabular-nums; }
  .ov-keys{ font-size:11px; color:var(--muted2); margin-top:12px; line-height:1.7; }
  .ov-keys kbd{ font-family:var(--mono); background:#0d1730; border:1px solid var(--line); border-bottom-width:2px; border-radius:5px; padding:1px 6px; font-size:11px; color:var(--text); }

  /* perk modal */
  .perks{ display:flex; gap:12px; justify-content:center; flex-wrap:wrap; margin-top:6px; }
  .perk{ width:150px; background:linear-gradient(180deg,#15233f,#0e1830); border:1px solid var(--line);
    border-radius:13px; padding:15px 13px; cursor:pointer; transition:transform .1s, border-color .15s, box-shadow .15s; text-align:left; }
  .perk:hover{ transform:translateY(-3px); border-color:var(--cyan); box-shadow:0 14px 30px -16px var(--cyan); }
  .perk .pi{ font-size:24px; margin-bottom:8px; }
  .perk .pn{ font-size:13.5px; font-weight:700; margin-bottom:5px; color:var(--text); }
  .perk .pd{ font-size:11px; color:var(--muted); line-height:1.45; }

  /* equipment modal */
  .eq{ max-width:560px; width:92%; text-align:left; background:linear-gradient(180deg,#101a31,#0b1325);
    border:1px solid var(--line); border-radius:16px; padding:18px; }
  .eq-h{ display:flex; align-items:center; gap:10px; margin-bottom:14px; }
  .eq-h .t{ font-size:17px; font-weight:700; letter-spacing:1px; }
  .eq-h .cores{ margin-left:auto; font-size:13px; color:var(--violet); font-weight:700; }
  .eq-h .x{ cursor:pointer; font-size:18px; color:var(--muted2); padding:2px 8px; border:1px solid var(--line); border-radius:8px; }
  .eq-slots{ display:grid; grid-template-columns:repeat(3,1fr); gap:9px; margin-bottom:8px; }
  .slot{ border:1px dashed #2a3a63; border-radius:11px; min-height:74px; padding:9px; display:flex; flex-direction:column; gap:3px;
    cursor:pointer; background:#0c1424; transition:border-color .15s; }
  .slot:hover{ border-color:var(--cyan); }
  .slot.filled{ border-style:solid; }
  .slot .sl-k{ font-size:8.5px; letter-spacing:1.4px; color:var(--muted2); text-transform:uppercase; }
  .eq-sub{ font-size:10px; color:var(--muted2); letter-spacing:1.5px; text-transform:uppercase; margin:12px 0 8px; }
  .inv{ display:grid; grid-template-columns:repeat(auto-fill,minmax(150px,1fr)); gap:8px; max-height:230px; overflow-y:auto; padding-right:4px; }
  .item{ border:1px solid var(--line); border-left:3px solid var(--rc); border-radius:10px; padding:9px; background:#0d1730; cursor:pointer; transition:transform .08s, border-color .15s; }
  .item:hover{ transform:translateY(-2px); }
  .item.equipped{ box-shadow:inset 0 0 0 1px var(--rc); }
  .it-name{ font-size:11.5px; font-weight:700; color:var(--rc); margin-bottom:3px; display:flex; justify-content:space-between; gap:6px; }
  .it-name .tag{ font-size:8px; letter-spacing:1px; color:var(--muted2); }
  .it-stats{ font-size:10px; color:var(--muted); line-height:1.5; }
  .it-stats b{ color:var(--text); }
  .it-actions{ display:flex; gap:6px; margin-top:7px; }
  .it-actions .btn{ flex:1; padding:5px 8px; font-size:10.5px; }
  .eq-empty{ grid-column:1/-1; text-align:center; color:var(--muted2); font-size:12px; padding:18px; }
  .eq-foot{ display:flex; gap:9px; align-items:center; margin-top:14px; border-top:1px solid var(--line); padding-top:12px; }
  .eq-foot .note{ font-size:10.5px; color:var(--muted2); }

  /* loot popup */
  .loot{ position:absolute; top:12px; right:12px; z-index:9; width:206px; transform:translateX(120%); transition:transform .35s cubic-bezier(.2,.9,.3,1); }
  .loot.show{ transform:translateX(0); }
  .loot-card{ border:1px solid var(--rc); border-left:4px solid var(--rc); border-radius:12px; padding:11px 12px;
    background:linear-gradient(180deg,#121d36,#0c1426); box-shadow:0 14px 34px -16px var(--rc); cursor:pointer; }
  .loot-k{ font-size:9px; letter-spacing:2px; color:var(--rc); text-transform:uppercase; margin-bottom:4px; }
  .loot-n{ font-size:13px; font-weight:700; color:var(--text); margin-bottom:5px; }
  .loot-s{ font-size:10.5px; color:var(--muted); line-height:1.5; }
  .loot-tap{ font-size:9px; color:var(--muted2); margin-top:7px; }

  /* float damage numbers (DOM projected) */
  .fx-float{ position:absolute; z-index:6; pointer-events:none; font-family:var(--font); font-weight:700;
    font-size:13px; text-shadow:0 1px 4px rgba(0,0,0,.7); will-change:transform,opacity; }
  .fx-float.crit{ font-size:19px; }

  .toast{ position:absolute; top:10px; left:50%; transform:translateX(-50%); z-index:8;
    background:linear-gradient(180deg,#19243f,#111a30); border:1px solid var(--line); border-radius:10px;
    padding:7px 13px; font-size:12px; color:var(--text); opacity:0; transition:opacity .25s, transform .25s; pointer-events:none; }
  .toast.show{ opacity:1; transform:translateX(-50%) translateY(2px); }

  .load-fail{ position:absolute; inset:0; display:none; place-items:center; text-align:center; z-index:20;
    background:rgba(7,10,20,.95); padding:30px; }
  .load-fail.show{ display:grid; }

  .hint{ text-align:center; color:var(--muted2); font-size:11px; margin-top:11px; letter-spacing:.3px; }

  @media (max-width:900px){ .stage{ grid-template-columns:1fr; } .sidebar{ order:2; } }
  @media (max-width:520px){ body{ padding:11px 9px 20px; } .title{ font-size:16px; letter-spacing:2px; } .chip{ padding:5px 8px; } .chip .v{ font-size:14px; } .cam-hint{ display:none; } }
</style>
</head>
<body>
<div id="app">
  <header>
    <div class="brand">
      <div class="logo"></div>
      <div><div class="title">NEON BASTION</div><div class="subtitle">3D · Grid Defense Protocol</div></div>
    </div>
    <div class="stats">
      <div class="chip wave"><span class="ic">🌊</span><div><div class="k">Wave</div><div class="v" id="hud-wave">0</div></div></div>
      <div class="chip lives"><span class="ic">❤</span><div><div class="k">Core</div><div class="v" id="hud-lives">20</div></div></div>
      <div class="chip gold"><span class="ic">◈</span><div><div class="k">Credits</div><div class="v" id="hud-gold">0</div></div></div>
      <div class="chip cores"><span class="ic">⬡</span><div><div class="k">Cores</div><div class="v" id="hud-cores">0</div></div></div>
      <div class="chip score"><span class="ic">★</span><div><div class="k">Score</div><div class="v" id="hud-score">0</div></div></div>
    </div>
  </header>

  <div class="stage">
    <div class="board-wrap">
      <div id="scene"></div>

      <div class="combo" id="combo"><div class="x">Combo</div><div class="n" id="combo-n">0</div><div class="mult" id="combo-mult">×1.0</div></div>
      <div class="toast" id="toast"></div>
      <div class="loot" id="loot"><div class="loot-card" id="loot-card"></div></div>

      <div class="controls">
        <button class="btn primary flash" id="btn-wave">Start Wave 1</button>
        <button class="btn icon" id="btn-pause" title="Pause / Resume (Space)">⏸</button>
        <button class="btn icon" id="btn-speed" title="Game speed">1×</button>
        <button class="btn icon on" id="btn-auto" title="Auto-start next wave">Auto</button>
        <button class="btn icon" id="btn-mute" title="Sound on / off">🔊</button>
      </div>
      <div class="cam-hint">drag <kbd>rotate</kbd> · scroll <kbd>zoom</kbd></div>

      <!-- start -->
      <div class="overlay show" id="ov-start">
        <div class="ov-card">
          <div class="ov-kicker">Sector 7 · Endless Assault</div>
          <div class="ov-title">NEON BASTION 3D</div>
          <div class="ov-text">
            Build <span class="hi">towers</span> on the grid to stop the waves before they reach your
            <span class="hi">core</span>. Crit, chain kills for combo, grab <span class="hi">loot</span> from bosses, pick
            <span class="hi">perks</span> every 5 waves, and drop an <span class="hi">Ion Strike</span> when it counts.
            Gear you collect carries over between runs.
          </div>
          <button class="btn primary" id="btn-begin" style="font-size:15px; padding:12px 26px;">▶ Deploy</button>
          <div class="ov-keys">
            <kbd>1</kbd>–<kbd>4</kbd> pick tower · <kbd>click</kbd> place · <kbd>drag</kbd> rotate camera<br/>
            <kbd>Q</kbd> Ion Strike · <kbd>E</kbd> Loadout · <kbd>Space</kbd> start/pause · <kbd>Esc</kbd> cancel
          </div>
        </div>
      </div>

      <!-- game over -->
      <div class="overlay" id="ov-over">
        <div class="ov-card">
          <div class="ov-kicker">Core Breached</div>
          <div class="ov-title lose">DEFENSE FAILED</div>
          <div class="ov-stats">
            <div class="ov-stat"><div class="k">Waves Held</div><div class="v" id="over-wave">0</div></div>
            <div class="ov-stat"><div class="k">Score</div><div class="v" id="over-score">0</div></div>
            <div class="ov-stat"><div class="k">Best</div><div class="v" id="over-best">0</div></div>
          </div>
          <div class="ov-text" id="over-msg"></div>
          <button class="btn primary" id="btn-restart" style="font-size:15px; padding:12px 26px;">↻ Redeploy</button>
        </div>
      </div>

      <!-- victory -->
      <div class="overlay" id="ov-win">
        <div class="ov-card">
          <div class="ov-kicker">Milestone Reached</div>
          <div class="ov-title win">SECTOR SECURED</div>
          <div class="ov-text">You cleared <span class="hi">20 waves</span>. The grid holds — now push into the endless tide for a new record.</div>
          <button class="btn primary" id="btn-continue" style="font-size:15px; padding:12px 26px;">⟶ Continue Endless</button>
        </div>
      </div>

      <!-- perk choice -->
      <div class="overlay" id="ov-perk">
        <div class="ov-card">
